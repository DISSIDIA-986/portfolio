# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.pnp.*

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
.env.local
.env.development.local
.env.test.local
.env.production.local

npm-debug.log*
yarn-debug.log*
yarn-error.log*
oss.md

# csv, xlsx
*.csv
*.xlsx

# resume generated artifacts (source is *.md, regenerate with ./resume/generate-pdfs.sh)
resume/*.html
resume/*.pdf

# images (allow project architecture SVGs)
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.svg
!public/favicon.svg
!public/images/projects/*.svg

# typescript
*.tsbuildinfo
next-env.d.ts

# vercel
.vercel

# allow .claude skill config
!.claude/
!.claude/**
.gstack/
